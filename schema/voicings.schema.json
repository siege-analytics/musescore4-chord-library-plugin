{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jazz Guitar Voicing Library",
  "description": "Schema for jazz guitar chord voicings used by the MuseScore 4 Chord Library Plugin",
  "type": "object",
  "required": ["voicings"],
  "properties": {
    "voicings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/voicing"
      }
    }
  },
  "$defs": {
    "voicing": {
      "type": "object",
      "required": [
        "id",
        "name",
        "chord_quality",
        "root",
        "category",
        "strings",
        "fret_number",
        "visible_frets",
        "dots",
        "mutes",
        "open",
        "notes",
        "intervals",
        "tags"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Unique identifier, lowercase with hyphens"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name, e.g. 'C7 — Shell 137 — E str'"
        },
        "chord_quality": {
          "type": "string",
          "minLength": 1,
          "description": "Chord quality identifier (e.g. maj7, dom7, min7, dom7b9, dom7sharp5). Free-text — imports can introduce new qualities."
        },
        "root": {
          "type": "string",
          "enum": ["C", "Db", "D", "Eb", "E", "F", "F#", "G", "Ab", "A", "Bb", "B"],
          "description": "Root note (all voicings stored as C for transposition)"
        },
        "category": {
          "type": "string",
          "minLength": 1,
          "description": "Voicing category (e.g. shell, drop2, drop3, extended, altered, quartal, caged). Free-text — imports can introduce new categories."
        },
        "suitableModes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["chord-melody", "comping", "solo-guitar", "duo"]
          },
          "minItems": 1,
          "uniqueItems": true,
          "description": "Modes this voicing is suited to. Replaces the legacy context field. Scoring engine treats this as a soft hint, not a hard filter."
        },
        "strings": {
          "type": "integer",
          "minimum": 4,
          "maximum": 12,
          "description": "Number of strings on the instrument (6=standard, 7=Van Eps/7-string, etc.)"
        },
        "tuning": {
          "type": "string",
          "description": "Tuning config name (matches a file in config/tunings/). Optional — defaults to 'standard'."
        },
        "fret_number": {
          "type": "integer",
          "minimum": 0,
          "maximum": 24,
          "description": "Starting fret position for the diagram"
        },
        "visible_frets": {
          "type": "integer",
          "minimum": 3,
          "maximum": 6,
          "description": "Number of frets shown in the diagram"
        },
        "dots": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["string", "fret"],
            "properties": {
              "string": {
                "type": "integer",
                "minimum": 1,
                "maximum": 12,
                "description": "String number (1=highest, numbering increases toward lowest)"
              },
              "fret": {
                "type": "integer",
                "minimum": 1,
                "maximum": 6,
                "description": "Fret position relative to fret_number (row 1 = fret_number)"
              }
            },
            "additionalProperties": false
          },
          "description": "Fingered positions on the fretboard"
        },
        "mutes": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12
          },
          "description": "Muted string numbers"
        },
        "open": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12
          },
          "description": "Open string numbers"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Note names in the voicing"
        },
        "intervals": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Interval labels (e.g. '1', 'b7', '3')"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Searchable tags"
        },
        "also_qualities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Additional chord qualities this voicing can serve (e.g. dom7 voicing also works as dom9)"
        },
        "shape_id": {
          "type": "string",
          "description": "Shape family identifier linking voicings that share the same physical fretboard shape"
        },
        "fingering": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["string", "finger"],
            "properties": {
              "string": {
                "type": "integer",
                "minimum": 1,
                "maximum": 12,
                "description": "String number"
              },
              "finger": {
                "type": "integer",
                "minimum": 0,
                "maximum": 4,
                "description": "Finger number (1=index, 2=middle, 3=ring, 4=pinky, 0=thumb)"
              }
            },
            "additionalProperties": false
          },
          "description": "Suggested left-hand fingering for each fretted string"
        }
      },
      "additionalProperties": false
    }
  }
}
